---
import { coreStrengths } from "../../data/skills";
---

<section class="px-6 py-24">

    <div class="container">

        <div class="mb-16">

            <p class="text-sm uppercase tracking-[0.28em] text-sky-400 font-semibold">
                Core Strengths
            </p>

            <h2 class="mt-4 text-4xl md:text-5xl font-bold">
                What I bring to a team.
            </h2>

        </div>

        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">

            {
                coreStrengths.map((strength) => (

                    <div
                        class="rounded-3xl border border-slate-800 bg-slate-900/60 p-8 transition duration-300 hover:border-sky-500 hover:-translate-y-2">

                        <div class="text-4xl">

                            {strength.icon}

                        </div>

                        <h3 class="mt-5 text-2xl font-bold">

                            {strength.title}

                        </h3>

                        <p class="mt-4 text-slate-400 leading-relaxed">

                            {strength.description}

                        </p>

                    </div>

                ))
            }

        </div>

    </div>

</section>